{
  "name": "@vobase/core",
  "version": "0.24.0",
  "license": "MIT",
  "description": "The app framework built for AI coding agents - core runtime",
  "repository": {
    "type": "git",
    "url": "https://github.com/vobase/vobase",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "import": "./src/db/helpers.ts",
      "types": "./src/db/helpers.ts",
      "default": "./src/db/helpers.ts"
    }
  },
  "files": [
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "test": "bun test src/; EXIT=$?; [ $EXIT -eq 99 ] && exit 0; exit $EXIT",
    "lint": "biome lint src/",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "hono": "^4.6.0",
    "drizzle-orm": "^1.0.0-beta.19",
    "better-auth": "^1.5.0",
    "@better-auth/api-key": "^1.5.0",
    "@electric-sql/pglite": "^0.4.1",
    "pg-boss": "^12.14.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "jose": "^6.2.2",
    "nanoid": "^5.1.7",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "drizzle-kit": "1.0.0-beta.19"
  }
}
