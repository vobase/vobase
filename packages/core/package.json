{
  "name": "@vobase/core",
  "version": "0.4.1",
  "license": "MIT",
  "description": "The app framework built for AI coding agents - core runtime",
  "repository": {
    "type": "git",
    "url": "https://github.com/vobase/vobase",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target=bun --sourcemap=inline && tsc -p tsconfig.build.json --emitDeclarationOnly --outDir ./dist",
    "dev": "bun run build --watch",
    "test": "bun test src/",
    "lint": "biome lint src/",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "hono": "^4.6.0",
    "drizzle-orm": ">=0.42.0",
    "better-auth": "^1.5.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "bunqueue": "^2.6.6",
    "nanoid": "^5.1.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.9"
  }
}
