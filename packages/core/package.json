{
  "name": "@vobase/core",
  "version": "0.33.0",
  "license": "MIT",
  "description": "The app framework built for AI coding agents - core runtime",
  "repository": {
    "type": "git",
    "url": "https://github.com/vobase/vobase",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "import": "./src/db/schema-exports.ts",
      "types": "./src/db/schema-exports.ts",
      "default": "./src/db/schema-exports.ts"
    },
    "./test-utils": {
      "import": "./src/test-utils.ts",
      "types": "./src/test-utils.ts",
      "default": "./src/test-utils.ts"
    }
  },
  "files": [
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "test": "bun test src/ tests/; EXIT=$?; [ $EXIT -eq 99 ] && exit 0; exit $EXIT",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "hono": "^4.6.0",
    "drizzle-orm": "^1.0.0-beta.21",
    "better-auth": "^1.5.0",
    "@better-auth/api-key": "^1.5.0",
    "@electric-sql/pglite": "^0.4.1",
    "pg-boss": "^12.14.0",
    "just-bash": "^2.14.2",
    "@mariozechner/pi-agent-core": "^0.67.68",
    "@mariozechner/pi-ai": "^0.67.68",
    "@sinclair/typebox": "^0.34.49"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "jose": "^6.2.2",
    "nanoid": "^5.1.9",
    "postgres": "^3.4.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@mariozechner/pi-agent-core": "^0.70.2",
    "@mariozechner/pi-ai": "^0.70.2",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "1.0.0-beta.23",
    "just-bash": "^2.14.2"
  }
}
