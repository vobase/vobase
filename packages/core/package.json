{
  "name": "@vobase/core",
  "version": "0.16.0",
  "license": "MIT",
  "description": "The app framework built for AI coding agents - core runtime",
  "repository": {
    "type": "git",
    "url": "https://github.com/vobase/vobase",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "import": "./src/db/helpers.ts",
      "types": "./src/db/helpers.ts",
      "default": "./src/db/helpers.ts"
    }
  },
  "files": [
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "test": "bun test src/",
    "lint": "biome lint src/",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "hono": "^4.6.0",
    "drizzle-orm": "^1.0.0-beta.18-7eb39f0",
    "better-auth": "^1.5.0",
    "@better-auth/api-key": "^1.5.0"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "pg-boss": "^10.1.7",
    "nanoid": "^5.1.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "drizzle-kit": "^1.0.0-beta.18-7eb39f0"
  }
}
