PORT=3000
TZ=Asia/Singapore

# ── Database ────────────────────────────────────────────────────────────────
# Port 5433 so template-v2 runs side-by-side with packages/template (port 5432)
TEMPLATE_V2_DATABASE_URL=postgres://vobase:vobase@localhost:5433/vobase_v2
DATABASE_URL=${TEMPLATE_V2_DATABASE_URL}

# ── White Label ─────────────────────────────────────────────────────────────
# VITE_PRODUCT_NAME=Vobase
# VITE_VENDOR_NAME=Vobase

# ── Better Auth ─────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-secret
BETTER_AUTH_URL=http://localhost:5173

# Restrict sign-up to these domains (comma-separated, leave unset to allow all)
# VITE_ALLOWED_EMAIL_DOMAINS=vobase.dev

# Multi-org mode (default: false, single org soft-locked). When true, users can
# create orgs and domain auto-join is disabled.
# VOBASE_MULTI_ORG=true

# ── LLM provider ────────────────────────────────────────────────────────────
# Bifrost gateway (production tenants — set by platform provisioning). When
# both BIFROST_* vars are set, the harness routes all LLM traffic through
# Bifrost instead of hitting providers directly.
# BIFROST_API_KEY=sk-bf-...
# BIFROST_URL=https://llm.vobase.app/v1

# Direct provider keys (local dev). Phase 2 critical path: Anthropic.
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...

# Override which provider the harness picks (default: anthropic)
# LLM_PROVIDER=anthropic

# ── Email (local dev uses MailDev on :1025, UI at http://localhost:1080) ────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@vobase.local
# SMTP_USER=          # Leave unset for MailDev (no auth)
# SMTP_PASS=

# ── Web channel ─────────────────────────────────────────────────────────────
# HMAC secret for verifying inbound POSTs to /api/channel-web/inbound.
# Required in production. In dev, falls back to 'dev-secret' (matches seed).
CHANNEL_WEB_WEBHOOK_SECRET=

# ── WhatsApp / Meta ─────────────────────────────────────────────────────────
# Required for channel-whatsapp to activate. Leave unset to disable the channel.
META_WA_TOKEN=
META_WA_VERIFY_TOKEN=
META_WA_PHONE_NUMBER_ID=

# ── Storage (default: local filesystem) ─────────────────────────────────────
# For Cloudflare R2 or S3, set R2_BUCKET and configure credentials:
# R2_BUCKET=
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# STORAGE_LOCAL_PATH=./data/files

# ── Vobase Platform Integration (opt-in) ────────────────────────────────────
# When connected to a Vobase platform instance, OAuth is handled by the
# platform which issues a signed JWT. Set PLATFORM_HMAC_SECRET to enable the
# /api/auth/platform-callback endpoint; the frontend OAuth buttons render when
# VITE_PLATFORM_URL + VITE_PLATFORM_TENANT_SLUG are set.
# PLATFORM_HMAC_SECRET=dev-local-hmac-secret-do-not-use-in-production
# VITE_PLATFORM_URL=http://localhost:3001
# VITE_PLATFORM_TENANT_SLUG=local
