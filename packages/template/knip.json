{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "main.ts",
    "runtime/bootstrap.ts",
    "runtime/modules.ts",
    "auth/index.ts",
    "auth/middleware/*.ts",
    "wake/*.ts",
    "modules/*/module.ts",
    "modules/*/cli.ts",
    "modules/*/agent.ts",
    "modules/*/seed.ts",
    "modules/*/jobs.ts",
    "modules/*/web.ts",
    "modules/*/verbs/*.ts",
    "modules/*/tools/*.ts",
    "modules/*/handlers/*.ts",
    "src/main.tsx",
    "scripts/*.ts",
    "tests/**/*.test.ts",
    "tests/e2e/**/*.ts",
    "tests/smoke/**/*.ts",
    "tests/helpers/**/*.ts",
    "modules/**/*.test.ts",
    "src/**/*.test.{ts,tsx}"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "modules/**/*.{ts,tsx}",
    "runtime/**/*.ts",
    "auth/**/*.ts",
    "wake/**/*.ts",
    "scripts/**/*.ts",
    "tests/**/*.ts"
  ],
  "ignore": [
    "src/components/ui/**",
    "src/components/ai-elements/**",
    "src/components/tool-ui/**",
    "src/components/chat/**"
  ],
  "ignoreDependencies": [
    "@fontsource-variable/geist",
    "embla-carousel-react",
    "tw-animate-css",
    "vaul",
    "shiki",
    "tailwindcss",
    "shadcn",
    "@tanstack/virtual-file-routes"
  ],
  "ignoreExportsUsedInFile": true
}
