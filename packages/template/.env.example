PORT=3000
TZ=Asia/Singapore

# --- White Label ---
# VITE_PRODUCT_NAME=Vobase
# VITE_VENDOR_NAME=Vobase

DATABASE_URL=postgres://vobase:vobase@localhost:5432/vobase

BETTER_AUTH_SECRET=change-me-to-a-random-32-char-secret
BETTER_AUTH_URL=http://localhost:5173

# --- Auth domain restriction (comma-separated, leave unset to allow all) ---
# VITE_ALLOWED_EMAIL_DOMAINS=vobase.dev

# --- Multi-org mode (default: false, single org soft-locked) ---
# Set by platform per-tenant. When true, users can create orgs and domain auto-join is disabled.
# MULTI_ORG=true

# --- AI Provider ---
# Bifrost gateway (production tenants — set by platform provisioning):
# BIFROST_API_KEY=sk-bf-...
# BIFROST_URL=https://llm.vobase.app/v1
#
# Direct provider keys (local dev — at least one required for messaging + knowledge base):
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_GENERATIVE_AI_API_KEY=...

# --- Email (local dev uses MailDev on port 1025, UI at http://localhost:1080) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@vobase.local
# SMTP_USER=          # Leave unset for MailDev (no auth)
# SMTP_PASS=

# --- WhatsApp Channel (Meta Embedded Signup — self-hosted only) ---
# META_APP_ID=
# META_APP_SECRET=
# META_CONFIG_ID=
META_WEBHOOK_VERIFY_TOKEN=dev-local-webhook-verify-token-do-not-use-in-production
# WEBHOOK_BASE_URL=https://your-tunnel.example.com  # Publicly reachable origin for Meta webhook callbacks (local dev only, falls back to BETTER_AUTH_URL)

# --- Storage (default: local filesystem) ---
# For Cloudflare R2 or S3, set storage provider to 's3' in vobase.config.ts and configure:
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# --- Cloudflare Browser Rendering (for web crawl connector) ---
# CLOUDFLARE_API_TOKEN=...
# CLOUDFLARE_ACCOUNT_ID=...

# --- Google Drive Connector (OAuth2) ---
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...

# --- SharePoint Connector (OAuth2) ---
# MICROSOFT_CLIENT_ID=...
# MICROSOFT_CLIENT_SECRET=...
# MICROSOFT_TENANT_ID=...

# --- Vobase Platform Integration (opt-in) ---
# When connected to a Vobase platform instance, credentials (WhatsApp, storage, etc.)
# are managed centrally. Set PLATFORM_HMAC_SECRET to enable platform routes.
# PLATFORM_URL=http://localhost:3001
# PLATFORM_HMAC_SECRET=dev-local-hmac-secret-do-not-use-in-production
# PLATFORM_TENANT_ID=local
# VITE_PLATFORM_URL=http://localhost:3001
# VITE_PLATFORM_TENANT_SLUG=local  # Override slug for local dev (production derives from hostname)
# VITE_PLATFORM_TENANT_NAME=My Company  # Tenant display name (used as default org name)
