PORT=3000
TZ=Asia/Singapore

DATABASE_URL=postgres://vobase:vobase@localhost:5432/vobase

BETTER_AUTH_SECRET=change-me-to-a-random-32-char-secret
BETTER_AUTH_URL=http://localhost:3000

# --- AI Provider (at least one required for messaging + knowledge base) ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_GENERATIVE_AI_API_KEY=...

# --- WhatsApp Channel (Meta Embedded Signup — self-hosted only) ---
# META_APP_ID=
# META_APP_SECRET=
# META_CONFIG_ID=
# META_WEBHOOK_VERIFY_TOKEN=
# META_WEBHOOK_CALLBACK_URL=https://localhost-5173.tunnel.example

# --- Storage (default: local filesystem) ---
# For Cloudflare R2 or S3, set storage provider to 's3' in vobase.config.ts and configure:
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# --- Cloudflare Browser Rendering (for web crawl connector) ---
# CLOUDFLARE_API_TOKEN=...
# CLOUDFLARE_ACCOUNT_ID=...

# --- Google Drive Connector (OAuth2) ---
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...

# --- SharePoint Connector (OAuth2) ---
# MICROSOFT_CLIENT_ID=...
# MICROSOFT_CLIENT_SECRET=...
# MICROSOFT_TENANT_ID=...

# --- Vobase Platform Integration (opt-in) ---
# When connected to a Vobase platform instance, credentials (WhatsApp, storage, etc.)
# are managed centrally. Set PLATFORM_HMAC_SECRET to enable platform routes.
# PLATFORM_HMAC_SECRET=
# PLATFORM_URL=http://localhost:3001
# VITE_PLATFORM_URL=http://localhost:3001
# VITE_PLATFORM_TENANT_SLUG=local  # Override slug for local dev (production derives from hostname)
