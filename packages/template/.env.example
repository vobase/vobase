PORT=3000

BETTER_AUTH_SECRET=change-me-to-a-random-32-char-secret
BETTER_AUTH_URL=http://localhost:3000

# --- AI Provider (at least one required for messaging + knowledge base) ---
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# ANTHROPIC_API_KEY=sk-ant-...

# --- AI Model Config (optional, defaults shown) ---
# AI_MODEL=gpt-4o-mini
# AI_EMBEDDING_MODEL=text-embedding-3-small
# AI_EMBEDDING_DIMENSIONS=1536

# --- WhatsApp Channel (Meta Embedded Signup) ---
# META_APP_ID=
# META_APP_SECRET=
# META_CONFIG_ID=
# META_WEBHOOK_VERIFY_TOKEN=

# --- Cloudflare Browser Rendering (for web crawl connector) ---
# CLOUDFLARE_API_TOKEN=...
# CLOUDFLARE_ACCOUNT_ID=...

# --- Google Drive Connector (OAuth2) ---
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...

# --- SharePoint Connector (OAuth2) ---
# MICROSOFT_CLIENT_ID=...
# MICROSOFT_CLIENT_SECRET=...
# MICROSOFT_TENANT_ID=...
