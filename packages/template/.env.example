PORT=3000
TZ=Asia/Singapore

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://vobase:vobase@localhost:5432/vobase

# Dedicated DSN for the LISTEN connection that drives realtime SSE.
# On Neon, DATABASE_URL points at the `-pooler` host (PgBouncer tx mode) for
# app queries — but pooled sessions silently drop LISTEN/NOTIFY. Set this to
# the direct (non-pooler) endpoint so the listener gets its own backend.
# Leave unset for self-hosted Postgres — the pool DSN is reused.
# DATABASE_URL_DIRECT=postgresql://user:pass@ep-xxx.region.aws.neon.tech/db?sslmode=require

# ── White Label ─────────────────────────────────────────────────────────────
# VITE_PRODUCT_NAME=Vobase
# VITE_VENDOR_NAME=Vobase

# ── Better Auth ─────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-secret
BETTER_AUTH_URL=http://localhost:5173

# Restrict sign-up to these domains (comma-separated, leave unset to allow all)
# VITE_ALLOWED_EMAIL_DOMAINS=vobase.dev

# Multi-org mode (default: false, single org soft-locked). When true, users can
# create orgs and domain auto-join is disabled.
# VOBASE_MULTI_ORG=true

# ── LLM provider ────────────────────────────────────────────────────────────
# Bifrost gateway (production tenants — set by platform provisioning). When
# both BIFROST_* vars are set, the harness routes all LLM traffic through
# Bifrost instead of hitting providers directly.
# BIFROST_API_KEY=sk-bf-...
# BIFROST_URL=https://llm.vobase.app/v1

# Direct provider keys (local dev). Phase 2 critical path: Anthropic.
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...

# Override which provider the harness picks (default: anthropic)
# LLM_PROVIDER=anthropic

# ── Email (local dev uses MailDev on :1025, UI at http://localhost:1080) ────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@vobase.local
# SMTP_USER=          # Leave unset for MailDev (no auth)
# SMTP_PASS=

# ── Web channel ─────────────────────────────────────────────────────────────
# HMAC secret for verifying inbound POSTs to /api/channel-web/inbound.
# Required in production. In dev, falls back to 'dev-secret' (matches seed).
CHANNEL_WEB_WEBHOOK_SECRET=

# ── WhatsApp / Meta ─────────────────────────────────────────────────────────
# Required for channel-whatsapp to activate. Leave unset to disable the channel.
META_WA_TOKEN=
META_WA_VERIFY_TOKEN=
META_WA_PHONE_NUMBER_ID=
# META_WA_APP_ID=
# META_WA_APP_SECRET=
# META_WA_API_VERSION=

# ── WhatsApp Embedded Signup ────────────────────────────────────────────────
# Required for the Embedded Signup flow at /api/channels/whatsapp/signup/*.
# Operator setup: see modules/channels/adapters/whatsapp/README.md.
# META_APP_ID=                              # numeric Facebook App ID
# META_APP_SECRET=                          # NEVER expose to the browser
# META_APP_CONFIG_ID_CLOUD=                 # FB Login for Business config (cloud)
# META_APP_CONFIG_ID_COEXISTENCE=           # FB Login for Business config (coexistence)
# META_APP_API_VERSION=v22.0                # optional, defaults to v22.0

# Set to '1' to enable inbound-message-body logging during local debugging.
# OFF by default — message bodies must NOT be logged in production.
# VOBASE_LOG_MESSAGE_BODIES=

# ── Storage (default: local filesystem) ─────────────────────────────────────
# For Cloudflare R2 or S3, set R2_BUCKET and configure credentials:
# R2_BUCKET=
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# STORAGE_LOCAL_PATH=./data/files

# ─── Managed WhatsApp Platform (optional) ───────────────────────────────────
# Set when this tenant should be auto-provisioned with a managed sandbox
# WhatsApp number from the platform service.

# Platform service base URL. Production: https://platform.voltade.app
PLATFORM_URL=

# Tenant id issued by the platform during provisioning.
PLATFORM_TENANT_ID=

# Comma-separated host allowlist for handshake target. Defends against
# malicious platformBaseUrl injection. e.g., "platform.voltade.app"
META_PLATFORM_HOSTNAME_ALLOWLIST=

# Set to "true" to auto-provision a managed sandbox on boot. Requires
# PLATFORM_URL, PLATFORM_TENANT_ID, PLATFORM_HMAC_SECRET to be set.
META_PLATFORM_AUTO_PROVISION=false

# ─── Reverse Proxy / IP Trust ───────────────────────────────────────────────
# Number of trusted proxy hops in front of this app. Used for X-Forwarded-For
# parsing. 0 = no proxy (use socket IP). 1 = single trusted proxy (e.g., Cloud
# Run, Vercel). 2 = two layers (Cloudflare → Cloud Run).
TRUST_PROXY_HOPS=0

# ── Vobase Platform Integration (opt-in) ────────────────────────────────────
# When connected to a Vobase platform instance, OAuth is handled by the
# platform which issues a signed JWT. Set PLATFORM_HMAC_SECRET to enable the
# /api/auth/platform-callback endpoint; the frontend OAuth buttons render when
# VITE_PLATFORM_URL + VITE_PLATFORM_TENANT_SLUG are set.
# PLATFORM_HMAC_SECRET=dev-local-hmac-secret-do-not-use-in-production
# VITE_PLATFORM_URL=http://localhost:3001
# VITE_PLATFORM_TENANT_SLUG=local
