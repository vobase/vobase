{
  "name": "@vobase/template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun --watch run server.ts\" \"bunx vite\"",
    "db:push": "bun --bun drizzle-kit push",
    "db:migrate": "bun --bun drizzle-kit migrate",
    "db:generate": "bun --bun drizzle-kit generate",
    "build": "bun build ./server.ts --outdir ./dist --target=bun"
  },
  "dependencies": {
    "radix-ui": "^1.4.3",
    "@fontsource-variable/geist": "^5.2.8",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.166.2",
    "@vobase/core": "workspace:*",
    "better-auth": "^1.5.4",
    "class-variance-authority": "^0.7.1",
    "cmdk": "^1.1.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "1.0.0-beta.16-ea816b6",
    "hono": "^4.12.5",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-vite-plugin": "^1.166.2",
    "@tanstack/virtual-file-routes": "^1.161.4",
    "@types/bun": "^1.3.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^1.0.0-beta.16-ea816b6",
    "shadcn": "^4.0.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
