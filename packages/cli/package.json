{
  "name": "@vobase/cli",
  "version": "0.6.1",
  "license": "MIT",
  "description": "The app framework built for AI coding agents - CLI and scaffolding",
  "deprecated": "Use create-vobase and template package.json scripts instead. See migration guide.",
  "repository": {
    "type": "git",
    "url": "https://github.com/vobase/vobase",
    "directory": "packages/cli"
  },
  "bin": {
    "vobase": "dist/bin.js"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/bin.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build ./src/bin.ts --outdir ./dist --target=bun --sourcemap=inline",
    "dev": "bun run build --watch",
    "test": "bun test src/commands/",
    "lint": "biome lint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vobase/core": "workspace:*",
    "concurrently": "^9.2.1",
    "giget": "^3.1.2"
  },
  "devDependencies": {
    "drizzle-kit": "^1.0.0-beta.16-ea816b6"
  }
}
