{
  "name": "@vobase/cli",
  "version": "0.1.0",
  "bin": {
    "vobase": "./dist/bin.js"
  },
  "type": "module",
  "scripts": {
    "build": "bun build ./src/bin.ts --outdir ./dist --target=bun --sourcemap=inline",
