      "--brand-foreground": "0 0% 100%",
      "--accent-purple": "271 76% 53%",
      "--accent-lavender": "275 82% 81%",
      "--background-light": "144 14% 97%",
      "--background-dark": "150 33% 10%",
      "--background-elevated": "0 0% 10%"
    },
    "fontFamily": {
      "display": "Space Grotesk, sans-serif"
