{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_FILE_PATH\" | grep -qE '(bun\\.lock|routeTree\\.gen\\.ts|node_modules/)' && echo 'BLOCK: Do not edit generated files' && exit 1 || exit 0"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "scripts/lint-file.sh \"$CLAUDE_FILE_PATH\""
          }
        ]
      }
    ]
  }
}
