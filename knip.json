{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "tags": ["-lintignore"],
  "ignoreWorkspaces": ["packages/core"],
  "workspaces": {
    ".": {
      "entry": "scripts/*.{ts,js}",
      "project": "scripts/**/*.{ts,js}",
      "ignoreDependencies": ["drizzle-kit", "drizzle-orm", "nanoid"]
    },
    "packages/template": {
      "entry": [
        "scripts/*.ts",
        "vobase.config.ts",
        "modules/*/index.ts",
        "modules/*/seed.ts",
        "modules/seed-types.ts",
        "modules/*/pages/**/layout.tsx",
        "mastra/**/*.ts"
      ],
      "project": [
        "src/**/*.{ts,tsx}",
        "modules/**/*.{ts,tsx}",
        "mastra/**/*.ts",
        "scripts/**/*.ts",
        "*.config.ts"
      ],
      "ignore": [
        "src/components/ai-elements/**",
        "src/components/ui/**",
        "src/lib/compose-refs.ts",
        "**/*.test.ts"
      ],
      "ignoreDependencies": [
        "shadcn",
        "mastra",
        "@fontsource-variable/geist",
        "tailwindcss",
        "tw-animate-css",
        "googleapis",
        "@azure/msal-node",
        "embla-carousel-react",
        "shiki",
        "streamdown",
        "vaul"
      ]
    },
    "packages/create-vobase": {
      "project": "**/*.ts",
      "ignoreBinaries": ["version"]
    }
  }
}
