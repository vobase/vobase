{
  "name": "vobase",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/*",
    "packages/cli/template"
  ],
  "scripts": {
    "ncu": "ncu --packageManager bun --format group --interactive --workspaces",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:fix": "biome check --write .",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "^1.3.10",
    "npm-check-updates": "^19.6.3",
    "turbo": "^2.8.14",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "nanoid": "^5.1.6"
  }
}
