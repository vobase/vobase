{
  "name": "vobase",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "ncu": "ncu --packageManager bun --format group --interactive --workspaces",
    "ncu:beta": "ncu --packageManager bun --format group --interactive --workspaces --target @beta",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:fix": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "bash scripts/release.sh",
    "check:lockfile": "bun run scripts/check-lockfile-workspaces.ts",
    "knip": "knip"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "knip": "^6.9.0",
    "npm-check-updates": "^22.0.1",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "drizzle-kit": "1.0.0-beta.23",
    "drizzle-orm": "1.0.0-beta.22",
    "nanoid": "^5.1.9"
  }
}
