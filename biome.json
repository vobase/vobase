{
  "$schema": "node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "packages/core/**",
      "packages/create-vobase/**",
      "!**/dist",
      "!**/*.gen.ts",
      "!**/*.generated.ts"
    ]
  },
  "linter": {
    "enabled": true,
    "domains": {
      "drizzle": "recommended",
      "project": "recommended",
      "react": "recommended",
      "test": "recommended",
      "turborepo": "recommended",
      "types": "recommended"
    },
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              [":NODE:"],
              [":URL:", ":PACKAGE:", ":PACKAGE_WITH_PROTOCOL:"],
              ":BLANK_LINE:",
              ["#*", "#*/**", ":ALIAS:"],
              [":PATH:"]
            ]
          }
        }
      }
    }
  }
}
